.shell powershell

# Reload app configuration
win + o                 : taskkill /f /im whkd.exe; ; start /b whkd.exe
win + shift + o         : komorebic stop; komorebic start --masir; start /b whkd.exe
win + shift + y         : taskkill /f /im yasb.exe; ; start yasb.exe

# Launch apps
win + shift + return	: start zen.exe
win + shift + k         : start keepassxc.exe
win + shift + n         : start code
win + return			: start cmd.exe

# Show keybinds
win + i                 : komorebic toggle-shortcuts

# Window actions
win + w                 : komorebic close
win + s                 : komorebic minimize
win + VK_OEM_3          : komorebic toggle-transparency # Tilda

# Window manager options
win + f         		: komorebic toggle-monocle
win + shift + f         : komorebic toggle-maximize
win + alt + r         	: komorebic retile
win + d         		: komorebic toggle-float # Float window
win + t                 : komorebic toggle-tiling # Pause current workspace
win + p                 : komorebic toggle-pause # Pause all komorebic functions
win + alt + x           : komorebic manage
win + shift + x         : komorebic unmanage

# Move windows
win + shift + a         : komorebic move left
win + shift + s         : komorebic move down
win + shift + w         : komorebic move up
win + shift + d         : komorebic move right

# Focus windows
ctrl + win + a          : komorebic focus left
ctrl + win + s          : komorebic focus down
ctrl + win + w          : komorebic focus up
ctrl + win + d          : komorebic focus right

# Move windows between monitors
win + shift + left       : komorebic cycle-move-to-monitor previous;
win + shift + right      : komorebic cycle-move-to-monitor next;

# Resize
win + oem_plus          : komorebic resize-axis horizontal increase
win + oem_minus         : komorebic resize-axis horizontal decrease
win + shift + oem_plus  : komorebic resize-axis vertical increase
win + shift + oem_minus : komorebic resize-axis vertical decrease

# Workspaces
win + 1                 : komorebic focus-workspace 0
win + 2                 : komorebic focus-workspace 1
win + 3                 : komorebic focus-workspace 2
win + 4                 : komorebic focus-workspace 3
win + 5                 : komorebic focus-workspace 4
win + 6                 : komorebic focus-workspace 5
win + 7                 : komorebic focus-workspace 6
win + 8                 : komorebic focus-workspace 7
win + 9                 : komorebic focus-workspace 8
win + 0                 : komorebic focus-workspace 9

# Cycle Workspaces
win + shift + tab       : komorebic cycle-workspace previous
win + tab               : komorebic cycle-workspace next
win + ctrl + shift + tab: komorebic cycle-move-to-workspace previous
win + ctrl + tab        : komorebic cycle-move-to-workspace next

# Move windows across workspaces
win + shift + 1         : komorebic move-to-workspace 0
win + shift + 2         : komorebic move-to-workspace 1
win + shift + 3         : komorebic move-to-workspace 2
win + shift + 4         : komorebic move-to-workspace 3
win + shift + 5         : komorebic move-to-workspace 4
win + shift + 6         : komorebic move-to-workspace 5
win + shift + 7         : komorebic move-to-workspace 6
win + shift + 8         : komorebic move-to-workspace 7
win + shift + 9         : komorebic move-to-workspace 8
win + shift + 0         : komorebic move-to-workspace 9