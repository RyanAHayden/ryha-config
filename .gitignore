# config
/.config/*
!/.config/yasb/

*.log
*.old

# Windhawk
/Windhawk/Engine
/Windhawk/ModsSource
/Windhawk/UIData/
!/Windhawk/UIData/user-data/User/settings.json

# FlowLauncher
/FlowLauncher/Cache
/FlowLauncher/Logs
/FlowLauncher/Plugins
/FlowLauncher/Settings/*
!/FlowLauncher/Settings/Settings.json

# PowerToys
/PowerToys/*
!/PowerToys/settings.json
!/PowerToys/Keyboard Manager/
/PowerToys/Keyboard Manager/*
!/PowerToys/Keyboard Manager/default.json
!/PowerToys/Keyboard Manager/editorSettings.json
!/PowerToys/Keyboard Manager/settings.json

# Backup files
*.bak
